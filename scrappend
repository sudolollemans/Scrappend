#!/usr/bin/env bash
set -euo pipefail

#-------------- ARG CHECK ------------------------

if [[ $# -eq 1 ]]; then
    name="$1"
    echo "Listing script $name."
else
    read -rp "Which script do you want to list? " name
fi

HOME_DIR="$HOME/Documents/Scripts/$name"
DEST_FILE="$HOME/Desktop/$name.txt"

#-------------- SOURCE DIR CHECK ------------------------

if [[ ! -d "$HOME_DIR" ]]; then
    echo "Script directory not found. Nothing happened."
    exit 1
else
    echo "Script directory $HOME_DIR found! Continuing script."
fi

#-------------- PREP DEST FILE  ------------------------

if [[ -f "$DEST_FILE" ]]; then
    echo "Destination file already exists. Creating clean new file."
    : > "$DEST_FILE"
else
    echo "$DEST_FILE doesn't exist yet! Creating new file."
    touch "$DEST_FILE"
fi

echo "Listing script $name in $DEST_FILE."

#-------------- APPEND MODULES ------------------------

if [[ -d "$HOME_DIR/modules" ]]; then
    echo "Appending lib modules first."

    shopt -s nullglob
    MODULES=("$HOME_DIR/modules"/*)
    shopt -u nullglob

    for module in "${MODULES[@]}"; do
        cat "$module" >> "$DEST_FILE"
    done
else
    echo "No libraries found. Skipping to main script."
fi

#-------------- APPEND MAIN ------------------------

cat "$HOME_DIR/$name" >> "$DEST_FILE"

echo "File created successfully at $DEST_FILE."
